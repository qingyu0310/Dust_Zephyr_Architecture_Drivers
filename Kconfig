# drivers/Kconfig - 底层硬件驱动抽象
# 提供 GPIO/PWM/UART/CAN 等外设驱动，以及 printk/shell 调试通道
# 每个 config 直接 select 对应的 Zephyr 子系统驱动符号

config DEV_GPIO
    default n
    bool "Enable simple GPIO device wrapper"
    select GPIO
    help
        Enable the lightweight GPIO wrappers in drivers/device/gpio.

config DEV_PWM
    default n
    bool "Enable simple PWM device wrapper"
    select PWM
    help
        Enable the lightweight PWM wrapper in drivers/device/pwm.

config COM_UART
    default n
    bool "UART interrupt driver"
    select SERIAL
    select UART_INTERRUPT_DRIVEN
    select UART_ASYNC_API
    help
        Enable the UART interrupt driver with ping-pong receive buffering.

config COM_UART_DMA
    default n
    bool "UART DMA driver"
    select SERIAL
    select UART_ASYNC_API
    help
        Enable the asynchronous DMA UART driver.

config COM_SPI
    default n
    bool "SPI driver"
    select SPI
    select GPIO
    help
        Enable the lightweight SPI wrapper in drivers/communication/spi.

config COM_CAN
    default n
    bool "CAN driver"
    select CAN
    help
        Enable the CAN driver. Board DTS must provide the CAN controller node.

config COM_RS485
    default n
    bool "RS485 half-duplex driver"
    select SERIAL
    select UART_ASYNC_API
    select GPIO
    help
        Enable the RS485 half-duplex driver using UART_ASYNC_API and a DE/RE GPIO.

config COM_CAN_STBY
    default n
    bool "Initialize CAN STBY pin"
    depends on COM_CAN
    select GPIO
    help
        Initialize the CAN transceiver STBY pin from board DTS overlay.
